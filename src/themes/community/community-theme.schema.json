{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "name", "author", "description", "tags", "config"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*-[a-z0-9]{4}$",
      "description": "Unique ID: {theme-name}-{4-char-suffix}"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 40
    },
    "author": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]+$"
    },
    "description": {
      "type": "string",
      "maxLength": 200
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "maxLength": 20 },
      "minItems": 1,
      "maxItems": 6
    },
    "preview": {
      "type": "string",
      "pattern": "\\.png$"
    },
    "config": {
      "type": "object",
      "required": ["algorithm", "token"],
      "properties": {
        "algorithm": {
          "enum": ["default", "dark", "compact", "darkCompact"]
        },
        "token": { "type": "object" },
        "components": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
