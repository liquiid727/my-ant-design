# Optional public build-time overrides for Theme Square.
# Leave these unset to use the canonical repository: liquiid727/my-ant-design.
VITE_COMMUNITY_REPO_OWNER=liquiid727
VITE_COMMUNITY_REPO_NAME=my-ant-design

# Override only when advanced theme bundles are published somewhere other than
# https://<owner>.github.io/<repo>/community-themes
# VITE_COMMUNITY_THEME_BASE_URL=https://example.com/community-themes
