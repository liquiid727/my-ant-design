{
  "name": "ant-design-theme-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run verify:tooling && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "verify:tooling": "vitest run src/services/docs/toolingGuideRegistry.test.ts",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "test:visual": "VISUAL_REGRESSION=1 playwright test e2e/theme-visual.spec.ts",
    "test:visual:update": "node scripts/verify-official-baseline.mjs && VISUAL_REGRESSION=1 playwright test e2e/theme-visual.spec.ts --update-snapshots"
  },
  "dependencies": {
    "@ant-design/compatible": "5.1.4",
    "@ant-design/fast-color": "3.0.1",
    "@ant-design/icons": "6.3.2",
    "@rc-component/util": "1.11.1",
    "@vitejs/plugin-react": "^4.3.1",
    "antd": "6.5.1",
    "antd-style": "4.1.0",
    "clsx": "2.1.1",
    "nanoid": "^5.0.7",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "^6.26.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.7.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.1"
  }
}
